---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const settingsEntries = await getCollection('settings');
const pageEntries = await getCollection('pages');

const siteSettings = settingsEntries.find((entry) => entry.id === 'site');
const homePage = pageEntries.find((entry) => entry.id === 'home');

if (!siteSettings || !homePage) {
  throw new Error('Required site content is missing.');
}
---

<BaseLayout title={homePage.data.title} siteName={siteSettings.data.siteName}>
  <header class="border-b border-slate-200">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
      <a href="/" class="text-sm font-semibold tracking-[0.12em] text-slate-900 uppercase">
        {siteSettings.data.siteName}
      </a>
      <nav aria-label="Primary" class="hidden gap-6 text-sm text-slate-700 md:flex">
        {siteSettings.data.navigation.map((item) => (
          <a href={item.href} class="transition hover:text-slate-950">
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <main>
    <section class="border-b border-slate-200 bg-slate-50">
      <div class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
        {homePage.data.eyebrow && (
          <p class="mb-6 text-xs font-semibold tracking-[0.18em] text-slate-600 uppercase">
            {homePage.data.eyebrow}
          </p>
        )}
        <h1 class="max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-6xl">
          {homePage.data.heroTitle}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-700">
          {homePage.data.heroDescription}
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href={homePage.data.primaryCtaHref}
            class="inline-flex items-center justify-center bg-slate-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-800"
          >
            {homePage.data.primaryCtaLabel}
          </a>
          {homePage.data.secondaryCtaLabel && homePage.data.secondaryCtaHref && (
            <a
              href={homePage.data.secondaryCtaHref}
              class="inline-flex items-center justify-center border border-slate-300 px-5 py-3 text-sm font-medium text-slate-900 transition hover:border-slate-400"
            >
              {homePage.data.secondaryCtaLabel}
            </a>
          )}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
      <div class="grid gap-8 md:grid-cols-3">
        <article class="border border-slate-200 p-6">
          <h2 class="text-lg font-semibold text-slate-950">Structured Content</h2>
          <p class="mt-3 text-sm leading-7 text-slate-700">
            The Astro scaffold is in place with typed content collections for pages, publications,
            team members, and site settings.
          </p>
        </article>
        <article class="border border-slate-200 p-6">
          <h2 class="text-lg font-semibold text-slate-950">Next Build Phase</h2>
          <p class="mt-3 text-sm leading-7 text-slate-700">
            The next implementation pass should add shared components, real content entries, and
            page routes for the seven required sections.
          </p>
        </article>
        <article class="border border-slate-200 p-6">
          <h2 class="text-lg font-semibold text-slate-950">Local Launch</h2>
          <p class="mt-3 text-sm leading-7 text-slate-700">
            Run <code>./scripts/start-local.sh</code> to install dependencies if needed and start
            the Astro dev server locally.
          </p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
