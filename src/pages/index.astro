---
import { getCollection } from 'astro:content';
import HighlightGrid from '../components/HighlightGrid.astro';
import PageHero from '../components/PageHero.astro';
import PublicationCard from '../components/PublicationCard.astro';
import SectionList from '../components/SectionList.astro';
import TeamCard from '../components/TeamCard.astro';
import { getPage, getSiteSettings } from '../lib/content';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteSettings = await getSiteSettings();
const homePage = await getPage('home');
const publications = await getCollection('publications');
const teamMembers = await getCollection('team');

const featuredPublications = publications
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const leadership = teamMembers
  .filter((entry) => entry.data.category === 'Leadership' && entry.data.active)
  .slice(0, 3);
---

<BaseLayout
  title={homePage.data.title}
  siteName={siteSettings.data.siteName}
  navigation={siteSettings.data.navigation}
  currentPath="/"
>
  <main>
    <PageHero
      eyebrow={homePage.data.eyebrow}
      title={homePage.data.heroTitle}
      description={homePage.data.heroDescription}
      lead={homePage.data.lead}
      primaryCtaLabel={homePage.data.primaryCtaLabel}
      primaryCtaHref={homePage.data.primaryCtaHref}
      secondaryCtaLabel={homePage.data.secondaryCtaLabel}
      secondaryCtaHref={homePage.data.secondaryCtaHref}
    />
    <HighlightGrid highlights={homePage.data.highlights} />
    <SectionList sections={homePage.data.sections} />

    <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <div class="flex items-end justify-between gap-6 border-b border-slate-200 pb-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-600">Featured Work</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Selected outputs</h2>
        </div>
        <a href="/publications" class="text-sm font-medium text-slate-950 underline-offset-4 hover:underline">
          View all publications
        </a>
      </div>
      <div class="mt-8 grid gap-6 lg:grid-cols-3">
        {featuredPublications.map((entry) => (
          <PublicationCard
            title={entry.data.title}
            summary={entry.data.summary}
            authors={entry.data.authors}
            category={entry.data.category}
            publishDate={entry.data.publishDate}
          />
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <div class="flex items-end justify-between gap-6 border-b border-slate-200 pb-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-600">Leadership</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Core team outline</h2>
        </div>
        <a href="/team" class="text-sm font-medium text-slate-950 underline-offset-4 hover:underline">
          View full team page
        </a>
      </div>
      <div class="mt-8 grid gap-6 lg:grid-cols-3">
        {leadership.map((entry) => (
          <TeamCard
            name={entry.data.name}
            positionTitle={entry.data.positionTitle}
            school={entry.data.school}
            graduationYearLabel={entry.data.graduationYearLabel}
            bioShort={entry.data.bioShort}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
