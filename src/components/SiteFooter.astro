---
interface Props {
  siteName: string;
}

const { siteName } = Astro.props;
---

<footer class="border-t border-[rgba(10,31,68,0.16)] bg-[#F8F9FA]">
  <div class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-10 text-sm text-black md:flex-row md:items-center md:justify-between">
    <p>{siteName}</p>
    <p>Institutional website outline in progress.</p>
  </div>
</footer>
