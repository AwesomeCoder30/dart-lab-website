---
interface Highlight {
  value: string;
  label: string;
}

interface Props {
  highlights: Highlight[];
}

const { highlights } = Astro.props;
---

{
  highlights.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <div class="grid gap-px border border-slate-200 bg-slate-200 md:grid-cols-3">
        {highlights.map((highlight) => (
          <article class="bg-white p-8">
            <p class="text-3xl font-semibold tracking-tight text-slate-950">{highlight.value}</p>
            <p class="mt-3 text-sm leading-7 text-slate-700">{highlight.label}</p>
          </article>
        ))}
      </div>
    </section>
  )
}
