---
interface Props {
  title: string;
  summary: string;
  authors: string[];
  category: string;
  publishDate: Date;
}

const { title, summary, authors, category, publishDate } = Astro.props;
const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border border-[rgba(10,31,68,0.16)] bg-[#F8F9FA] p-6">
  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#0A1F44]">{category}</p>
  <h2 class="mt-4 text-xl font-semibold tracking-tight text-black">{title}</h2>
  <p class="mt-4 text-sm leading-7 text-black">{summary}</p>
  <div class="mt-6 text-sm text-black">
    <p>{authors.join(', ')}</p>
    <p class="mt-1">{formattedDate}</p>
  </div>
</article>
