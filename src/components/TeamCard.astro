---
interface Props {
  name: string;
  school: string;
  graduationYearLabel: string;
  bioShort: string;
  positionTitle?: string;
}

const { name, school, graduationYearLabel, bioShort, positionTitle } = Astro.props;
---

<article class="border border-slate-200 p-6">
  <h3 class="text-lg font-semibold text-slate-950">{name}</h3>
  {positionTitle && <p class="mt-2 text-sm font-medium text-slate-700">{positionTitle}</p>}
  <p class="mt-2 text-sm text-slate-600">{school} {graduationYearLabel}</p>
  <p class="mt-4 text-sm leading-7 text-slate-700">{bioShort}</p>
</article>
